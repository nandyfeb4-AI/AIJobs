generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplyMode {
  individual
  batch
}

enum ApplicationStage {
  saved
  applied
  screening
  interview
  offer
  rejected
}

enum JobStatus {
  active
  stale
  inactive
}

enum BoardSyncStatus {
  unverified
  working
  empty
  failed
}

enum CandidateCompanyStatus {
  candidate
  discovering
  discovered
  no_supported_board
  failed
  promoted
}

enum CandidateBoardStatus {
  discovered
  validating
  validated
  rejected
  promoted
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  authId       String         @unique
  email        String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  profile      Profile?
  resumes      Resume[]
  matches      JobMatch[]
  tailoringRuns TailoringRun[]
  applications Application[]
}

model Profile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  headline          String?
  targetRoles       String[]
  preferredLocation String?
  remotePreference  String?
  salaryFloor       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  name          String
  baseFileUrl   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      ResumeVersion[]
  tailoringRuns TailoringRun[]
}

model ResumeVersion {
  id            String         @id @default(uuid()) @db.Uuid
  resumeId      String         @db.Uuid
  jobId         String?        @db.Uuid
  versionLabel  String
  fileUrl       String
  atsScore      Int?
  createdAt     DateTime       @default(now())
  resume        Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job           Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  applications  Application[]
}

model Job {
  id             String         @id @default(uuid()) @db.Uuid
  sourceId       String?
  sourceKey      String         @unique
  sourceName     String
  boardToken     String?
  title          String
  company        String
  companyDomain  String?
  companyLogoUrl String?
  location       String?
  employmentType String?
  salaryMin      Int?
  salaryMax      Int?
  remoteType     String?
  description    String
  applyUrl       String
  postedAt       DateTime?
  sourceUpdatedAt DateTime?
  firstSeenAt    DateTime       @default(now())
  lastSeenAt     DateTime       @default(now())
  lastSyncedAt   DateTime       @default(now())
  contentHash    String?
  status         JobStatus      @default(active)
  syncCount      Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  matches        JobMatch[]
  versions       ResumeVersion[]
  applications   Application[]
  tailoringRuns  TailoringRun[]

  @@index([sourceName, boardToken])
  @@index([status, postedAt])
}

model SourceBoard {
  id                String          @id @default(uuid()) @db.Uuid
  sourceName        String
  boardToken        String
  company           String
  companyDomain     String?
  tier              String?
  status            BoardSyncStatus @default(unverified)
  active            Boolean         @default(true)
  lastCheckedAt     DateTime?
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  lastFailureReason String?
  lastSeenJobCount  Int?
  lastTargetJobCount Int?
  totalPersistedJobs Int            @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([sourceName, boardToken])
  @@index([status, sourceName])
}

model CandidateCompany {
  id                 String                 @id @default(uuid()) @db.Uuid
  company            String
  companyDomain      String?
  homepage           String
  careersUrl         String?
  segments           String[]
  sourceHint         String?
  confidence         Float?
  origin             String?
  notes              String?
  status             CandidateCompanyStatus @default(candidate)
  lastDiscoveredAt   DateTime?
  lastDiscoveryError String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  candidateBoards    CandidateBoard[]

  @@unique([company, homepage])
  @@index([status, sourceHint])
}

model CandidateBoard {
  id                 String               @id @default(uuid()) @db.Uuid
  candidateCompanyId String               @db.Uuid
  sourceName         String
  boardToken         String
  evidenceUrl        String?
  status             CandidateBoardStatus @default(discovered)
  validationError    String?
  validatedAt        DateTime?
  promotedAt         DateTime?
  promotedBoardId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  candidateCompany   CandidateCompany     @relation(fields: [candidateCompanyId], references: [id], onDelete: Cascade)

  @@unique([sourceName, boardToken, candidateCompanyId])
  @@index([status, sourceName])
}

model JobMatch {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  jobId       String   @db.Uuid
  score       Float
  reasons     Json
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model TailoringRun {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  resumeId        String   @db.Uuid
  jobId           String   @db.Uuid
  promptVersion   String
  modelProvider   String
  modelName       String
  status          String
  diffSummary     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Application {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  jobId            String           @db.Uuid
  resumeVersionId  String?          @db.Uuid
  applyMode        ApplyMode
  stage            ApplicationStage @default(saved)
  appliedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion?   @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
}
