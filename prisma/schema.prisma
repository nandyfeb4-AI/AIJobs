generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplyMode {
  individual
  batch
}

enum ApplicationStage {
  saved
  applied
  screening
  interview
  offer
  rejected
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  authId       String         @unique
  email        String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  profile      Profile?
  resumes      Resume[]
  matches      JobMatch[]
  tailoringRuns TailoringRun[]
  applications Application[]
}

model Profile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  headline          String?
  targetRoles       String[]
  preferredLocation String?
  remotePreference  String?
  salaryFloor       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  name          String
  baseFileUrl   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      ResumeVersion[]
  tailoringRuns TailoringRun[]
}

model ResumeVersion {
  id            String         @id @default(uuid()) @db.Uuid
  resumeId      String         @db.Uuid
  jobId         String?        @db.Uuid
  versionLabel  String
  fileUrl       String
  atsScore      Int?
  createdAt     DateTime       @default(now())
  resume        Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job           Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  applications  Application[]
}

model Job {
  id             String         @id @default(uuid()) @db.Uuid
  sourceId       String?
  sourceName     String
  title          String
  company        String
  location       String?
  employmentType String?
  salaryMin      Int?
  salaryMax      Int?
  remoteType     String?
  description    String
  applyUrl       String
  postedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  matches        JobMatch[]
  versions       ResumeVersion[]
  applications   Application[]
  tailoringRuns  TailoringRun[]
}

model JobMatch {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  jobId       String   @db.Uuid
  score       Float
  reasons     Json
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model TailoringRun {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  resumeId        String   @db.Uuid
  jobId           String   @db.Uuid
  promptVersion   String
  modelProvider   String
  modelName       String
  status          String
  diffSummary     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Application {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  jobId            String           @db.Uuid
  resumeVersionId  String?          @db.Uuid
  applyMode        ApplyMode
  stage            ApplicationStage @default(saved)
  appliedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion?   @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
}
